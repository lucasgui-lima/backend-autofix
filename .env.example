# ────────────────────────────────────────────────────────
# Gestão de Manutenção — Configuração do Backend
# ────────────────────────────────────────────────────────
# Copie este arquivo como .env e preencha os valores.
# cp .env.example .env

# ─── Banco de Dados ────────────────────────────────────
# Desenvolvimento (SQLite):
# DATABASE_URL=sqlite:///./manutencao.db
#
# Produção — PostgreSQL do Supabase:
# 1. Acesse https://supabase.com → New project
# 2. Vá em Project Settings → Database → Connection string
# 3. Escolha "URI" e copie a string
# 4. Substitua [YOUR-PASSWORD] pela senha do banco
# 5. Adicione +psycopg2 depois de postgres
#
# Exemplo:
# DATABASE_URL=postgresql+psycopg2://postgres:abc123@db.xxxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql+psycopg2://postgres:S@gui126307@db.tltuihtisnmmabojukal.supabase.co:5432/postgres

# ─── Segredo JWT ────────────────────────────────────────
# Gere uma chave forte com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TROQUE-ESTA-CHAVE-EM-PRODUCAO-9f8a7b6c

# ─── CORS ───────────────────────────────────────────────
# Origens permitidas (separadas por vírgula sem espaço)
# Para app web Flet: URL onde o app web será hospedado
# Para desenvolvimento, mantenha * (libera tudo)
CORS_ORIGINS=*
